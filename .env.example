# 环境变量配置模板

# Tushare 数据源配置
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_API_URL=http://tushare.xyz

# LLM 提供商配置
LLM_PROVIDER=zhipu

# 智谱 AI 配置
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4

# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=taurus_aquant
POSTGRES_USER=taurus
POSTGRES_PASSWORD=taurus123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 应用配置
APP_NAME=Taurus-AQuant
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Streamlit 配置
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Streamlit 配置
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# 数据配置
DATA_CACHE_DIR=./data/cache
DATA_UPDATE_TIME=18:00

# 风控配置
RISK_MAX_POSITION_PCT=0.3
RISK_MAX_DAILY_TRADES=10
RISK_STOP_LOSS_PCT=-0.05
RISK_STOP_PROFIT_PCT=0.10
